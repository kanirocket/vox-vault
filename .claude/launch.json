{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vox-vault",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start", "--prefix", "backend"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "vox-frontend-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 4030,
      "autoPort": true,
      "env": { "VITE_API_TARGET": "http://localhost:4031" }
    }
  ]
}
