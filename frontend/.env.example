# Google Sign-In — OAuth 2.0 Web client ID from Google Cloud Console.
# Copy this file to `.env` for local dev (Vite reads it at build/serve time).
# For Docker builds, set GOOGLE_CLIENT_ID in the environment instead (it is
# passed through to the frontend build as VITE_GOOGLE_CLIENT_ID).
VITE_GOOGLE_CLIENT_ID=

# Backend target for the dev server's /api proxy (defaults to :4031).
VITE_API_TARGET=http://localhost:4031
